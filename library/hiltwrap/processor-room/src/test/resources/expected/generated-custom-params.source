package org.chapp.library.hiltwrap.room

import android.content.Context
import androidx.room.Room
import dagger.Module
import dagger.Provides
import dagger.hilt.InstallIn
import dagger.hilt.android.qualifiers.ApplicationContext
import javax.inject.Singleton

@Module
@InstallIn(TestComponent::class)
internal class TestDatabaseCustomParametersHiltWrapRoomModule {
  @Provides
  public fun providesDatabase(@ApplicationContext context: Context): TestDatabaseCustomParameters = Room.databaseBuilder(context, TestDatabaseCustomParameters::class.java, "test_database").build()

  @Provides
  @Singleton
  public fun provideTestDao1(database: TestDatabaseCustomParameters): TestDao1 = database.testDao1()

  @Provides
  @Singleton
  public fun provideTestDao2(database: TestDatabaseCustomParameters): TestDao2 = database.testDao2
}
