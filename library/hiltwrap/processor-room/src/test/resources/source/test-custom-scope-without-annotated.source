package ch.app.library.hiltwrap.room

import androidx.room.Dao
import androidx.room.Database
import androidx.room.Entity
import androidx.room.Insert
import androidx.room.RoomDatabase
import ch.app.library.hiltwrap.annotation.HiltWrapRoomDao
import ch.app.library.hiltwrap.annotation.HiltWrapRoomModule
import dagger.hilt.DefineComponent
import javax.inject.Singleton

@Entity
data class TestEntity1(val id: Int)
@Dao
interface TestDao1 {
    @Insert fun insert(item: TestEntity1)
}

@Entity
data class TestEntity2(val id: Int)
@Dao
interface TestDao2 {
    @Insert fun insert(item: TestEntity2)
}

interface TestScope

@Database(
    entities = [
        TestEntity1::class,
        TestEntity2::class,
    ],
    version = 1,
)
@HiltWrapRoomModule(
    databaseName = "test_database",
)
internal abstract class TestScopeWithoutAnnotated : RoomDatabase() {
    @HiltWrapRoomDao(scope = TestScope::class) abstract fun testDao1(): TestDao1
    @HiltWrapRoomDao(scope = TestScope::class) abstract val testDao2: TestDao2
}